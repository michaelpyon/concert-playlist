# Get your API key at https://api.setlist.fm/docs/1.0/index.html
SETLISTFM_API_KEY=your_setlistfm_api_key_here

# Get your API key at https://console.cloud.google.com/apis/credentials
# Enable "YouTube Data API v3" in your Google Cloud project
YOUTUBE_API_KEY=your_youtube_api_key_here

# OAuth Client ID for "Save to YouTube" feature
# Create at https://console.cloud.google.com/apis/credentials (OAuth 2.0 Client ID, Web application)
# Add authorized JS origins: http://localhost:5173, https://your-domain.com
VITE_GOOGLE_CLIENT_ID=your_google_oauth_client_id_here
